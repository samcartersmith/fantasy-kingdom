# FantasyPros official API (email support for a key). Without it, ingest uses src/data/news/fantasypros-news.fixture.json
FANTASYPROS_API_KEY=

# Protect POST /api/cron/news-ingest (Vercel Cron sends Authorization: Bearer <secret>)
CRON_SECRET=

# Optional override for JSON news store directory (default: .data/news)
NEWS_STORE_DIR=

# Phase 2: Yahoo Fantasy OAuth (developer.yahoo.com)
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
YAHOO_REDIRECT_URI=http://localhost:3000/api/yahoo/callback
